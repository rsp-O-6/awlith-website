# Optional: set this if you have a separately deployed awlith_api backend.
AWLITH_API_BASE_URL=http://127.0.0.1:8000

# Preferred for the existing Netlify site: let /api/contact write directly to Postgres.
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DB_SSLMODE=require
